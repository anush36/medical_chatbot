# OpenAI API Configuration
OPENAI_API_KEY=your_openai_api_key_here

# Model Configuration
# Set to "openai" to use OpenAI API, "local" to use local model
MODEL_PROVIDER=local

# MedGemma Configuration
MEDGEMMA_BASE_URL=https://your-cloud-run-url.run.app/v1
MEDGEMMA_API_KEY=fake-key
MEDGEMMA_MODEL=google/medgemma-4b-it

# OpenAI Model Configuration (when using OpenAI)
OPENAI_MODEL=gpt-3.5-turbo
OPENAI_MAX_TOKENS=150
OPENAI_TEMPERATURE=0.7
