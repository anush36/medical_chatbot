# Provider Configuration
# Set to "local" (default), "openai", or "medgemma"
MODEL_PROVIDER=local

# ---------------------------------------------------------
# Option A: Local Model Configuration (Default)
# ---------------------------------------------------------
LOCAL_MODEL_NAME=microsoft/phi-2
LOCAL_MAX_TOKENS=64

# ---------------------------------------------------------
# Option B: OpenAI API Configuration
# ---------------------------------------------------------
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-3.5-turbo
OPENAI_MAX_TOKENS=150
OPENAI_TEMPERATURE=0.7

# ---------------------------------------------------------
# Option C: MedGemma (Cloud Run) Configuration
# ---------------------------------------------------------
MEDGEMMA_BASE_URL=https://your-cloud-run-url.run.app/v1
MEDGEMMA_API_KEY=fake-key
MEDGEMMA_MODEL=google/medgemma-4b-it
